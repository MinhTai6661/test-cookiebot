#lead {
  padding: 44vw 0 15vw;
}

#lead h2 {
  font-weight: 400;
  font-size: 2.5vw;
  color: #d41322;
  letter-spacing: 2.7em;
  text-align: center;
  text-transform: uppercase;
  margin-bottom: 3vw;
}

#lead .group {
  background: #fff;
  position: relative;
  z-index: 1;
  margin-bottom: 5vw;
}

#lead .group::before {
  content: "";
  position: absolute;
  background: url(../img/dinner/lead_smoke.png) no-repeat;
  background-size: contain;
  aspect-ratio: 360/560;
  width: 33.3vw;
  height: auto;
  bottom: 19vw;
  left: 20vw;
  mix-blend-mode: screen;
  z-index: 3;
}

#lead .ramen {
  margin: -11vw 0 0 5vw;
  position: relative;
  z-index: 2;
}

#lead h3 {
  margin-bottom: 10vw;
}

#lead .desc .group {
  margin-bottom: 18px;
}

#lead .desc .group:last-child {
  margin-bottom: 0;
}

#lead .desc .txt {
  margin-bottom: 18px;
  text-align: left;
}

#lead .desc .txt:last-child {
  margin-bottom: 0;
}

@media only screen and (max-width: 767px) {
  #lead .wrap {
    padding: 0 3%;
  }
  #lead h3 ,
  #lead .desc{
    padding: 0 3.6666666667%;
  }
}

@media only screen and (min-width: 768px) {
  #lead {
    padding: 319px 0 126px;
  }

  #lead .wrap {
    /*max-width: 1500px;*/
        max-width: calc(100%);
    padding: 0 17px;
    margin: 0 auto;
    width: 100%;
  }
  #lead .wrap .img img{
        object-fit: cover;
    width: 100%;
  }

  #lead h2 {
    font-size: 19px;
    letter-spacing: 5.65em;
    margin-left: 100px;
    margin-bottom: 23px;
  }

  #lead .group {
    margin-bottom: 44px;
    overflow: hidden;
  }

  #lead .group::before {
    width: 360px;
    bottom: unset;
    top: 416px;
    left: calc(50% - 293px);
  }

  #lead .ramen {
    text-align: center;
    margin: -141px 0 0 30px;
  }

  #lead h3 {
    text-align: center;
    margin-bottom: 38px;
  }

  #lead .desc {
    display: flex;
    justify-content: center;
    gap: 32px;
  }

  #lead .desc .group {
    width: 390px;
    margin-bottom: 0;
  }

  #lead .desc .txt {
    text-align: left;
    font-size: 18px;
    margin-bottom: 27px;
  }

  #lead .desc .txt:last-child {
    margin-bottom: 0;
  }
}

#bnr {
  padding: 5vw 0 20vw;
}

#bnr .bnr-wrap {
  position: relative;
  height: 92vw;
}

#bnr .link {
  position: absolute;
  z-index: 3;
  inset: 0;
}

#bnr h2 {
  font-weight: 500;
  color: #fff;
  letter-spacing: normal;
  font-size: 6.7vw;
  position: absolute;
  top: 5vw;
  left: 5vw;
  z-index: 1;
  line-height: 1.45em;
}

#bnr .btn-all {
  position: absolute;
  bottom: 5vw;
  right: 5vw;
}

#bnr .wrap-slider {
  position: absolute;
  z-index: -1;
  inset: 0;
  height: 92vw;
}

#bnr .slider {
  line-height: 1em;
  height: 100%;
}

#bnr .slider .slick-list {
  height: 100%;
}

#bnr .slider .slick-slide {
  height: 92vw;
}

#bnr .slider .slick-slide>div {
  height: 100%;
}

#bnr .slider .img {
  height: 100%;
}

#bnr .slider img {
  object-fit: cover;
  width: 100%;
  height: 100%;
}

@media only screen and (min-width: 768px) {
  #bnr {
    padding: 0 0 141px;
  }

  #bnr .wrap {
    max-width: 1450px;
    padding: 0 25px;
    margin: 0 auto;
    width: 100%;
  }

  #bnr .bnr-wrap {
    position: relative;
    height: 650px;
    transition: all 0.3s ease;
  }

  .overlay {
    background: #000;
    position: absolute;
    inset: 0;
    opacity: 0;
    z-index: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  #bnr .bnr-wrap:hover .overlay {
    opacity: 0.5;
    visibility: visible;
  }

  #bnr h2 {
    font-size: 70px;
    top: 102px;
    left: 61px;
    line-height: 1.05em;
    transform: scaleY(1.3);
  }

  #bnr .btn-all {
    bottom: 42px;
    right: 45px;
  }

  #bnr .btn-all .fk {
    width: 427px;
  }

  #bnr .wrap-slider {
    height: 650px;
  }

  #bnr .slider .slick-slide {
    height: 650px;
  }
}

