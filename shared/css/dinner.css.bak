.btn-popup {
  text-align: center;
}

.btn-popup a {
  margin: 0 auto;
  width: 280px;
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  text-align: center;
  color: #fff;
  background: #d41322;
  position: relative;
  font-family: var(--mar);
  font-weight: 400;
  font-size: 16px;
}

.btn-popup a::before {
  content: "";
  position: absolute;
  background: url(../img/shared/icon_popup.png) no-repeat;
  background-size: contain;
  background-position: center;
  aspect-ratio: 1/1;
  width: 12px;
  height: auto;
  top: 0;
  bottom: 0;
  margin: auto 0;
  right: 20px;
}

@media only screen and (min-width: 768px) {
  .btn-popup a {
    width: 700px;
    height: 100px;
    font-size: 30px;
    transition: all 0.3s ease-out;
    overflow: hidden;
    z-index: 1;
  }

  .btn-popup a::before {
    width: 24px;
    right: 35px;
    transition: all 0.3s ease-out;
  }

  .btn-popup a::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: #000;
    border-radius: 100%;
    transform: scale(0);
    transition: all 0.3s ease-out;
    z-index: -1;
  }

  .btn-popup a:hover::after {
    transform: scale(2);
  }
}

#set {
  position: relative;
  padding-bottom: 15vw;
}

#set::before {
  content: "";
  position: absolute;
  background: #c7c7c5;
  bottom: 0;
  left: 6.6666666667%;
  right: 6.6666666667%;
  height: 1px;
}

#set .wrap {
  background: #e4e4e4;
  padding: 10vw 6.6% 12vw;
}

#set h2 {
  line-height: 1.5;
  text-align: center;
  margin-bottom: 10vw;
}

#set h2 .bg {
  display: inline-block;
  background: #d41322;
